# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,*.vercel.app

# Database (PostgreSQL on Vercel)
DATABASE_URL=postgresql://user:password@hostname:5432/database_name

# Security
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://*.vercel.app

# Optional: AWS S3 for static files
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_STORAGE_BUCKET_NAME=your-bucket
